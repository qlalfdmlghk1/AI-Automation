{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(cd:*)",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(npm:*)",
      "Bash(npx eslint:*)",
      "Bash(npx playwright:*)",
      "Bash(npx prettier:*)",
      "Bash(npx vue-tsc:*)",
      "Bash(glab:*)",
      "Skill(commit)",
      "Skill(commit *)",
      "Skill(note)",
      "Skill(note *)",
      "Skill(mr)",
      "Skill(mr *)",
      "Skill(start)",
      "Skill(start *)",
      "Skill(review)",
      "Skill(review *)",
      "Skill(secure-review)",
      "Skill(secure-review *)",
      "Skill(tech-doc)",
      "Skill(tech-doc *)",
      "Skill(organize-imports)",
      "Skill(organize-imports *)",
      "Skill(e2e)",
      "Skill(e2e *)",
      "WebFetch",
      "mcp__figma__get_variable_defs",
      "mcp__figma__get_screenshot",
      "mcp__playwright__*",
      "mcp__atlassian__*"
    ],
    "deny": [
      "Bash(npm exec:*)",
      "Bash(npm x:*)",
      "Bash(npm explore:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/check-commit-typecheck.js",
            "timeout": 300
          },
          {
            "type": "command",
            "command": "node .claude/hooks/warn-changelog-on-mr.js"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/notify-sensitive-edit.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/warn-e2e-antipattern.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/format-edited.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pilot-session-metrics.mjs"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pilot-session-metrics.mjs"
          }
        ]
      }
    ]
  }
}
